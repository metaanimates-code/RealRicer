#!/usr/bin/env bash

THEMES_DIR="$HOME/.config/themes"

# Theme display names -> directory names
declare -A MENU
MENU["Catppuccin Mocha"]="catppuccin-mocha"
MENU["Monochrome"]="monochrome"

apply_theme() {
  local theme="$1"
  local wallpaper="$2"
  local dir="$THEMES_DIR/$theme"

  local waybar_css="$dir/waybar.css"
  local kitty_conf="$dir/kitty.conf"

  [[ ! -f "$wallpaper" ]] && { notify-send "Theme" "No wallpaper selected"; return 1; }
  [[ ! -f "$waybar_css" ]] && { notify-send "Theme" "No waybar.css for $theme"; return 1; }
  [[ ! -f "$kitty_conf" ]] && { notify-send "Theme" "No kitty.conf for $theme"; return 1; }

  # Set wallpaper
  awww img "$wallpaper"
  echo "$wallpaper" > "$HOME/.cache/wallpaper-state"
  echo "$theme" > "$HOME/.cache/current-theme"
  echo "${WP_SOURCE[$theme]}" > "$HOME/.cache/current-theme-wp-src"

  # Waybar colors
  cp "$waybar_css" "$HOME/.config/waybar/colors.css"
  inline_waybar_style

  # Kitty
  cp "$kitty_conf" "$HOME/.config/kitty/current-theme.conf"

  # Wofi
  [[ -f "$dir/wofi.css" ]] && cp "$dir/wofi.css" "$HOME/.config/wofi/colors.css"

  # Hyprlock
  # Update wallpaper path in hyprlock
  sed -i "0,/^[[:space:]]*path = /s|^[[:space:]]*path = .*|    path = $wallpaper|" "$HOME/.config/hypr/hyprlock.conf"

  local hv="$dir/hyprlock.vars"
  if [[ -f "$hv" ]]; then
    source "$hv"
    local hc="$HOME/.config/hypr/hyprlock.conf"
    sed -i \
      -e "s|^\$accent = .*|\$accent = rgb($ACCENT_RGB)|" \
      -e "s|^\$text = .*|\$text = rgb($TEXT_RGB)|" \
      -e "s|color = rgb(.*|color = rgb($TIME_RGB)|" \
      -e "s|fail_color = rgb(.*|fail_color = rgb($FAIL_RGB)|" \
      -e "s|capslock_color = rgb(.*|capslock_color = rgb($CAPSLOCK_RGB)|" \
      "$hc"

    # Update window border colors in hyprland.conf
    sed -i \
      -e "s|^\$themeBorder = .*|\$themeBorder = $BORDER_RGBA|" \
      -e "s|^\$themeBorderInactive = .*|\$themeBorderInactive = $BORDER_INACTIVE_RGBA|" \
      "$HOME/.config/hypr/hyprland.conf"
    hyprctl reload 2>/dev/null
  fi

  # Restart waybar
  killall waybar 2>/dev/null; waybar &

  # Reload kitty
  /usr/bin/pkill -x -USR1 kitty 2>/dev/null

  notify-send "Theme" "Switched to $theme"
}

inline_waybar_style() {
  local colors="$HOME/.config/waybar/colors.css"
  local template="$HOME/dotfiles/waybar/.config/waybar/style.css"
  local output="$HOME/.config/waybar/style.css"

  declare -A vars
  while IFS=' ' read -r _ name val _; do
    val="${val%;}"
    [[ -n "$name" && -n "$val" ]] && vars["$name"]="$val"
  done < <(grep '@define-color' "$colors")

  local line
  while IFS= read -r line; do
    [[ "$line" == @import* ]] && continue
    for name in "${!vars[@]}"; do
      line="${line//\@$name/${vars[$name]}}"
    done
    echo "$line"
  done < "$template" > "$output"
}

# --- Generate theme data if missing ---
mkdir -p "$THEMES_DIR"

