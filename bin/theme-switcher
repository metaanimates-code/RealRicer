# --- Wallpaper source directories per theme ---
declare -A WP_SOURCE
WP_SOURCE["catppuccin-mocha"]="$THEMES_DIR/catppuccin-mocha/wallpapers"
WP_SOURCE["monochrome"]="$HOME/Monochrome"

pick_wallpaper() {
  local src="$1"
  local files=()
  while IFS= read -r -d '' f; do
    files+=("$f")
  done < <(find "$src" -maxdepth 1 -type f \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' \) -print0 2>/dev/null)
  [[ ${#files[@]} -eq 0 ]] && return 1
  echo "${files[RANDOM % ${#files[@]}]}"
}

# --- Entry point ---
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  entries=()
  for key in "${!MENU[@]}"; do
    entries+=("$key")
  done

  IFS=$'\n' sorted=($(sort <<<"${entries[*]}")); unset IFS

  theme_chosen=$(printf "%s\n" "${sorted[@]}" | wofi --dmenu --prompt "Theme" --width 300 --height 200 2>/dev/null)
  [[ -z "$theme_chosen" ]] && exit 0

  theme_key="${MENU[$theme_chosen]}"
  wp_src="${WP_SOURCE[$theme_key]}"

  [[ ! -d "$wp_src" ]] && { notify-send "Theme" "No wallpaper source for $theme_key"; exit 1; }

  wallpaper=$(pick_wallpaper "$wp_src")
  [[ -z "$wallpaper" ]] && { notify-send "Theme" "No wallpapers found in $wp_src"; exit 1; }

  apply_theme "$theme_key" "$wallpaper"
fi
